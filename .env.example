# ── SBI LifePulse Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── REQUIRED ────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── OPTIONAL: Frontend API URL (change if deploying) ───────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── OPTIONAL: Force offline demo mode (no API calls, uses cache) ────────────
# Set to "true" on demo day if internet is unreliable
# DEMO_OFFLINE_MODE=false

# ── OPTIONAL: Twilio (for REAL WhatsApp on demo day — the ₹2.5L moment) ───
# Setup guide: localhost:3000/twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_DEMO_PHONE=whatsapp:+91XXXXXXXXXX
